# ── MongoDB Atlas ─────────────────────────────────────────
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/finvault?retryWrites=true&w=majority

# ── JWT Secret (any long random string) ──────────────────
JWT_SECRET=change_this_to_something_long_and_secret_min_32_chars

# ── Email (Gmail SMTP for verification emails) ────────────
# For Gmail: enable 2FA → App Password → use that as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password_16_chars

# ── App URL (for email verification links) ───────────────
# Render: https://finvault.onrender.com
# Vercel: https://finvault.vercel.app
BASE_URL=https://your-app-url.com

# ── Port (set automatically by Render/Vercel) ────────────
PORT=3000
